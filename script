    clearWallHL()
    if not CFG.WallShootOn then return end
    for _,p in ipairs(Players:GetPlayers()) do
        if not isEnemy(p) then continue end
        local ch=p.Character; if not ch then continue end
        local h=Instance.new("Highlight")
        h.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
        h.FillColor=Color3.fromRGB(255,60,80)
        h.FillTransparency=0.4
        h.OutlineColor=Color3.fromRGB(255,220,80)
        h.OutlineTransparency=0
        h.Adornee=ch; h.Parent=ch
        State.wallHL[#State.wallHL+1]=h
    end
