-- Animate nebula drift
task.spawn(function()
    local t=0
    while main and main.Parent do
        task.wait(0.05); t=t+0.016
        for i,neb in ipairs(State.nebulaObjs) do
            local off=math.sin(t*0.3+i*1.1)*3
            neb.Position=UDim2.new(
                neb.Position.X.Scale, neb.Position.X.Offset,
                neb.Position.Y.Scale, neb.Position.Y.Offset+off*0.02
            )
        end
        -- Animate border color
        local rc=hsv((t*0.08)%1,0.9,1)
        border.Color=rc
        accentLine.BackgroundColor3=rc
    end
end)

-- в”Ђв”Ђ MENU TOGGLE в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
UserInput.InputBegan:Connect(function(inp,gp)
    if gp then return end
    local k=inp.KeyCode

    if k==Enum.KeyCode.Insert then
        State.menuOpen=not State.menuOpen
        if State.menuOpen then
            main.Visible=true
            main.BackgroundTransparency=0.9
            tw(main,{BackgroundTransparency=0},0.25,Enum.EasingStyle.Back)
            -- Staggered star reveal
            for i,star in ipairs(State.starObjs) do
                task.delay(i*0.003,function()
                    if star and star.Parent then
                        tw(star,{BackgroundTransparency=star.BackgroundTransparency*0.3},0.4)
                    end
                end)
            end
        else
            tw(main,{BackgroundTransparency=1},0.2)
            task.delay(0.22,function() if not State.menuOpen then main.Visible=false end end)
        end
    end

    -- Hotkeys
    if k==Enum.KeyCode.End then
        CFG.AimOn=not CFG.AimOn
        if CFG.AimOn then startAimbot() else stopAimbot() end
    end
    if k==Enum.KeyCode.G then
        CFG.FlyOn=not CFG.FlyOn
        if CFG.FlyOn then startFly() else stopFly() end; saveCFG()
    end
    if k==Enum.KeyCode.N then
        CFG.NoclipOn=not CFG.NoclipOn
        if CFG.NoclipOn then startNoclip() else stopNoclip() end; saveCFG()
    end
    if k==Enum.KeyCode.F then
        CFG.FreecamOn=not CFG.FreecamOn
        if CFG.FreecamOn then startFreecam() else stopFreecam() end; saveCFG()
    end
    if k==Enum.KeyCode.B then
        CFG.WallShootOn=not CFG.WallShootOn
        applyWallHL(); saveCFG()
    end
end)

