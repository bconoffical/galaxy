    -- to enemy characters temporarily when shooting
    if State.wConn then State.wConn:Disconnect() end
    State.wConn = Players.PlayerAdded:Connect(function(p2)
        p2.CharacterAdded:Connect(function()
            task.wait(0.8); if CFG.WallShootOn then applyWallHL() end
        end)
    end)
end

