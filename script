local function isEnemy(p)
    if p == LP then return false end
    if p.Team and LP.Team and p.Team == LP.Team then return false end
    return true
end

local function tw(obj, props, t, style)
    TweenService:Create(obj, TweenInfo.new(t or 0.2,
        style or Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props):Play()
end

local function hsv(h,s,v)
    h=h%1; local i=math.floor(h*6); local f=h*6-i
    local p=v*(1-s); local q=v*(1-f*s); local r=v*(1-(1-f)*s)
    local t2={{v,r,p},{q,v,p},{p,v,r},{p,q,v},{r,p,v},{v,p,q}}
    local c=t2[(i%6)+1]; return Color3.new(c[1],c[2],c[3])
end

-- Raycast from camera to world pos to check visibility
local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude
local function isVisible(targetPos)
    local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local origin = Cam.CFrame.Position
    local dir    = (targetPos - origin)
    rayParams.FilterDescendantsInstances = {LP.Character, workspace.CurrentCamera}
    local result = workspace:Raycast(origin, dir, rayParams)
    if not result then return true end  -- nothing hit, clear line of sight
    -- If the hit is very close to target, consider visible
    return (result.Position - targetPos).Magnitude < 2
end

