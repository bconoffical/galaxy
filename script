-- DRAWING — clean crosshair only
-- ══════════════════════════════════════
local CLEN, CGAP = 10, 5

local function initDrawing()
    pcall(function()
        local function ln(col, thick)
            local l = Drawing.new("Line")
            l.Visible=false; l.Thickness=thick or 1.8
            l.Color=col; l.Transparency=0
            return l
        end
        -- 4-arm gap crosshair
        State.crossH   = ln(Color3.fromRGB(255,80,80))
        State.crossV   = ln(Color3.fromRGB(255,80,80))
        State.crossTop = ln(Color3.fromRGB(255,80,80))
        State.crossBot = ln(Color3.fromRGB(255,80,80))
        -- Center dot
        State.crossDot = Drawing.new("Circle")
        State.crossDot.Visible=false; State.crossDot.Filled=true
        State.crossDot.Radius=2.5; State.crossDot.Thickness=1
        State.crossDot.Color=Color3.fromRGB(255,255,255)
        State.crossDot.Transparency=0
        -- Thin lock ring (subtle, only shows when locked)
        State.crossRing = Drawing.new("Circle")
        State.crossRing.Visible=false; State.crossRing.Filled=false
        State.crossRing.Radius=14; State.crossRing.Thickness=1.2
        State.crossRing.Color=Color3.fromRGB(255,100,100)
        State.crossRing.Transparency=0.35
    end)
end

local function showCross(sp, col)
    pcall(function()
        local cx, cy = sp.X, sp.Y
        local c = col or Color3.fromRGB(255,80,80)
        State.crossH.From   = Vector2.new(cx-CLEN-CGAP, cy)
        State.crossH.To     = Vector2.new(cx-CGAP, cy)
        State.crossH.Color  = c; State.crossH.Visible=true
        State.crossV.From   = Vector2.new(cx+CGAP, cy)
        State.crossV.To     = Vector2.new(cx+CLEN+CGAP, cy)
        State.crossV.Color  = c; State.crossV.Visible=true
        State.crossTop.From = Vector2.new(cx, cy-CLEN-CGAP)
        State.crossTop.To   = Vector2.new(cx, cy-CGAP)
        State.crossTop.Color= c; State.crossTop.Visible=true
        State.crossBot.From = Vector2.new(cx, cy+CGAP)
        State.crossBot.To   = Vector2.new(cx, cy+CLEN+CGAP)
        State.crossBot.Color= c; State.crossBot.Visible=true
        State.crossDot.Position = Vector2.new(cx, cy)
        State.crossDot.Color    = Color3.fromRGB(255,255,255)
        State.crossDot.Visible  = true
        State.crossRing.Position = Vector2.new(cx, cy)
        State.crossRing.Visible  = true
    end)
end

local function hideCross()
    pcall(function()
        for _, k in ipairs({"crossH","crossV","crossTop","crossBot","crossDot","crossRing"}) do
            if State[k] then State[k].Visible = false end
        end
    end)
end

