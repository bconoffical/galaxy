UserInput.InputBegan:Connect(function(inp,gp)
    if gp then return end
    local k=inp.KeyCode
    if k==gkey("Menu") then
        State.menuOpen=not State.menuOpen
        if State.menuOpen then
            main.Visible=true; main.BackgroundTransparency=0.92
            tw(main,{BackgroundTransparency=0},0.2)
        else
            tw(main,{BackgroundTransparency=1},0.16)
            task.delay(0.18,function() if not State.menuOpen then main.Visible=false end end)
        end
    end
    if k==gkey("Aimbot") then
        CFG.AimOn=not CFG.AimOn
        if CFG.AimOn then startAimbot() else stopAimbot() end
    end
    if k==gkey("Fly") then
        CFG.FlyOn=not CFG.FlyOn
        if CFG.FlyOn then startFly() else stopFly() end; saveCFG()
    end
    if k==gkey("Noclip") then
        CFG.NoclipOn=not CFG.NoclipOn
        if CFG.NoclipOn then startNoclip() else stopNoclip() end; saveCFG()
    end
    if k==gkey("WallHack") then
        CFG.WallHackOn=not CFG.WallHackOn
        applyWallHL(); saveCFG()
    end
end)

