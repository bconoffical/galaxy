local CROSS_LEN = 10
local CROSS_GAP = 4

local function initCrosshair()
    pcall(function()
        State.crossH = Drawing.new("Line")
        State.crossH.Visible = false; State.crossH.Thickness = 1.5
        State.crossH.Color = Color3.fromRGB(255,80,80); State.crossH.Transparency = 0

        State.crossV = Drawing.new("Line")
        State.crossV.Visible = false; State.crossV.Thickness = 1.5
        State.crossV.Color = Color3.fromRGB(255,80,80); State.crossV.Transparency = 0

        State.crossTop = Drawing.new("Line")
        State.crossTop.Visible = false; State.crossTop.Thickness = 1.5
        State.crossTop.Color = Color3.fromRGB(255,80,80); State.crossTop.Transparency = 0

        State.crossBot = Drawing.new("Line")
        State.crossBot.Visible = false; State.crossBot.Thickness = 1.5
        State.crossBot.Color = Color3.fromRGB(255,80,80); State.crossBot.Transparency = 0

        State.crossDot = Drawing.new("Circle")
        State.crossDot.Visible = false; State.crossDot.Radius = 2.5
        State.crossDot.Filled = true; State.crossDot.Color = Color3.fromRGB(255,255,255)
        State.crossDot.Transparency = 0; State.crossDot.Thickness = 1

        -- FOV ring follows mouse cursor
        State.fovRing = Drawing.new("Circle")
        State.fovRing.Visible = false; State.fovRing.Radius = CFG.AimFOV
        State.fovRing.Filled = false; State.fovRing.Color = Color3.fromRGB(160,60,255)
        State.fovRing.Transparency = 0.4; State.fovRing.Thickness = 1.5
    end)
end

local function updateCrosshair(sp, locked)
    if not State.crossH then return end
    pcall(function()
        local cx, cy = sp.X, sp.Y
        local col = locked and Color3.fromRGB(255,60,60) or Color3.fromRGB(255,220,60)

        State.crossH.From = Vector2.new(cx - CROSS_LEN - CROSS_GAP, cy)
        State.crossH.To   = Vector2.new(cx - CROSS_GAP, cy)
        State.crossH.Color = col; State.crossH.Visible = true

        State.crossV.From = Vector2.new(cx + CROSS_GAP, cy)
        State.crossV.To   = Vector2.new(cx + CROSS_LEN + CROSS_GAP, cy)
        State.crossV.Color = col; State.crossV.Visible = true

        State.crossTop.From = Vector2.new(cx, cy - CROSS_LEN - CROSS_GAP)
        State.crossTop.To   = Vector2.new(cx, cy - CROSS_GAP)
        State.crossTop.Color = col; State.crossTop.Visible = true

        State.crossBot.From = Vector2.new(cx, cy + CROSS_GAP)
        State.crossBot.To   = Vector2.new(cx, cy + CROSS_LEN + CROSS_GAP)
        State.crossBot.Color = col; State.crossBot.Visible = true

        State.crossDot.Position = Vector2.new(cx, cy)
        State.crossDot.Color = locked and Color3.fromRGB(255,60,60) or Color3.fromRGB(255,255,255)
        State.crossDot.Radius = locked and 3 or 2
        State.crossDot.Visible = true
    end)
end

local function updateFOVRing(mousePos)
    pcall(function()
        if State.fovRing then
            State.fovRing.Position = mousePos
            State.fovRing.Radius   = CFG.AimFOV
            State.fovRing.Visible  = CFG.AimOn
        end
    end)
end

local function hideCrosshair()
    pcall(function()
        if State.crossH   then State.crossH.Visible   = false end
        if State.crossV   then State.crossV.Visible   = false end
        if State.crossTop then State.crossTop.Visible = false end
        if State.crossBot then State.crossBot.Visible = false end
        if State.crossDot then State.crossDot.Visible = false end
    end)
end

initCrosshair()

