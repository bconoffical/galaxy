    l.TextXAlignment=Enum.TextXAlignment.Left; l.Text=txt
end

local function mkBind(par,label,bindKey)
    local row=mkRow(par); mkLbl(row,label)
    local btn=Instance.new("TextButton",row)
    btn.Size=UDim2.new(0,130,0,28); btn.Position=UDim2.new(1,-138,0.5,-14)
    btn.BackgroundColor3=Color3.fromRGB(20,6,50); btn.BorderSizePixel=0
    btn.TextColor3=Color3.fromRGB(200,140,255); btn.Font=Enum.Font.GothamBold; btn.TextSize=12
    btn.Text="[ "..BINDS[bindKey].." ]"
    Instance.new("UICorner",btn).CornerRadius=UDim.new(0,8)
    Instance.new("UIStroke",btn).Color=Color3.fromRGB(120,40,200)
    local waiting=false
    btn.MouseButton1Click:Connect(function()
        if waiting then return end; waiting=true
        btn.Text="[ ... ]"; btn.TextColor3=Color3.fromRGB(255,180,60)
        local c; c=UserInput.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.Keyboard then
                local n=tostring(inp.KeyCode):gsub("Enum%.KeyCode%.","")
                BINDS[bindKey]=n
                btn.Text="[ "..n.." ]"
                btn.TextColor3=Color3.fromRGB(200,140,255)
                waiting=false; c:Disconnect(); saveCFG()
            end
        end)
    end)
end

local function mkOption(par,txt,options,get,set)
    local row=mkRow(par); mkLbl(row,txt)
    local btn=Instance.new("TextButton",row)
    btn.Size=UDim2.new(0,130,0,28); btn.Position=UDim2.new(1,-138,0.5,-14)
    btn.BackgroundColor3=Color3.fromRGB(30,8,70); btn.BorderSizePixel=0
    btn.TextColor3=Color3.fromRGB(200,160,255); btn.Font=Enum.Font.GothamBold; btn.TextSize=12
    btn.Text=get()
    Instance.new("UICorner",btn).CornerRadius=UDim.new(0,8)
    Instance.new("UIStroke",btn).Color=Color3.fromRGB(120,40,200)
    btn.MouseButton1Click:Connect(function()
        local cur=get(); local idx=1
        for i,v in ipairs(options) do if v==cur then idx=i; break end end
        idx=(idx%#options)+1
        set(options[idx]); btn.Text=options[idx]; saveCFG()
    end)
end

