-- FREECAM
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
local function stopFreecam()
    if State.fcConn then State.fcConn:Disconnect(); State.fcConn=nil end
    UserInput.MouseBehavior=Enum.MouseBehavior.Default
    if not CFG.AimOn then Cam.CameraType=Enum.CameraType.Custom end
end

local function startFreecam()
    Cam.CameraType=Enum.CameraType.Scriptable
    State.fcCF=Cam.CFrame
    local _,y=Cam.CFrame:ToEulerAnglesYXZ()
    State.fcYaw=y; State.fcPitch=0
    UserInput.MouseBehavior=Enum.MouseBehavior.LockCenter
    if State.fcConn then State.fcConn:Disconnect() end
    State.fcConn=RunService.RenderStepped:Connect(function(dt)
        if not CFG.FreecamOn then stopFreecam(); return end
        local d=UserInput:GetMouseDelta()
        State.fcYaw=State.fcYaw-d.X*0.004
        State.fcPitch=math.clamp(State.fcPitch-d.Y*0.004,-1.5,1.5)
        local rot=CFrame.Angles(0,State.fcYaw,0)*CFrame.Angles(State.fcPitch,0,0)
        local mv=Vector3.zero; local sp=CFG.FreecamSpeed*dt
        if UserInput:IsKeyDown(Enum.KeyCode.W) then mv+=rot.LookVector end
        if UserInput:IsKeyDown(Enum.KeyCode.S) then mv-=rot.LookVector end
        if UserInput:IsKeyDown(Enum.KeyCode.A) then mv-=rot.RightVector end
        if UserInput:IsKeyDown(Enum.KeyCode.D) then mv+=rot.RightVector end
        if UserInput:IsKeyDown(Enum.KeyCode.Space) then mv+=Vector3.yAxis end
        if UserInput:IsKeyDown(Enum.KeyCode.LeftControl) then mv-=Vector3.yAxis end
        if mv.Magnitude>0 then
            State.fcCF=CFrame.new(State.fcCF.Position+mv.Unit*sp)*rot
        else
            State.fcCF=CFrame.new(State.fcCF.Position)*rot
        end
        Cam.CFrame=State.fcCF
    end)
end

