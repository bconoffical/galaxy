-- HOTKEY HANDLER (reads live BINDS table)
-- ══════════════════════════════════════
UserInput.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
    local keyName = tostring(inp.KeyCode):gsub("Enum%.KeyCode%.","")

    if keyName == BINDS.MenuKey then
        State.menuOpen = not State.menuOpen
        if State.menuOpen then
            main.Visible=true; main.BackgroundTransparency=0.9
            tw(main,{BackgroundTransparency=0},0.25,Enum.EasingStyle.Back)
        else
            tw(main,{BackgroundTransparency=1},0.2)
            task.delay(0.22,function() if not State.menuOpen then main.Visible=false end end)
        end
    end

    if keyName == BINDS.AimKey then
        CFG.AimOn = not CFG.AimOn
        if CFG.AimOn then startAimbot() else stopAimbot() end
        saveCFG()
    end

    if keyName == BINDS.FlyKey then
        CFG.FlyOn = not CFG.FlyOn
        if CFG.FlyOn then startFly() else stopFly() end
        saveCFG()
    end

    if keyName == BINDS.NoclipKey then
        CFG.NoclipOn = not CFG.NoclipOn
        if CFG.NoclipOn then startNoclip() else stopNoclip() end
        saveCFG()
    end
end)

