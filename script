-- ══════════════════════════════════════
-- AIMBOT — Cursor-only lock (mousemoverel)
--
-- Does NOT touch the camera.
-- Every RenderStepped:
--   1. Get current mouse position
--   2. For each enemy, project their target bone (Head or Torso) to screen
--   3. If within AimFOV px of cursor AND within max world dist → candidate
--   4. Pick closest candidate to cursor
--   5. Move cursor toward target using mousemoverel (smooth lerp)
--   6. Draw crosshair at target screen pos
-- ══════════════════════════════════════
local function stopAimbot()
    if State.aimConn then State.aimConn:Disconnect(); State.aimConn=nil end
    hideCrosshair()
    pcall(function()
        if State.fovRing then State.fovRing.Visible = false end
    end)
    State.lockedTarget = nil
end

local function startAimbot()
    stopAimbot()

    State.aimConn = RunService.RenderStepped:Connect(function()
        if not CFG.AimOn then return end

        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not root then hideCrosshair(); return end

        local mousePos = UserInput:GetMouseLocation()
        updateFOVRing(Vector2.new(mousePos.X, mousePos.Y))

        local bestPart   = nil
        local bestPlayer = nil
        local bestDist   = math.huge

        for _,p in ipairs(Players:GetPlayers()) do
            if not isEnemy(p) then continue end
            local ch = p.Character; if not ch then continue end

            -- Select bone based on config
            local bone = ch:FindFirstChild(CFG.AimBone)
            if not bone then
                bone = ch:FindFirstChild("HumanoidRootPart")
            end
            if not bone then continue end

            local worldDist = (bone.Position - root.Position).Magnitude
            if worldDist > CFG.AimMaxDist then continue end

            local sp, onScreen = Cam:WorldToViewportPoint(bone.Position)
            if not onScreen then continue end

            local screenBone = Vector2.new(sp.X, sp.Y)
            local cursorDist = (screenBone - Vector2.new(mousePos.X, mousePos.Y)).Magnitude

            if cursorDist <= CFG.AimFOV and cursorDist < bestDist then
                bestDist   = cursorDist
                bestPart   = bone
                bestPlayer = p
            end
        end

        if bestPart then
            local sp2, _ = Cam:WorldToViewportPoint(bestPart.Position)
            local targetScreen = Vector2.new(sp2.X, sp2.Y)
            local currentMouse = Vector2.new(mousePos.X, mousePos.Y)

            -- Move cursor toward target via smooth lerp delta
            local delta = targetScreen - currentMouse
            local smoothed = delta * math.clamp(CFG.AimSmooth, 0.01, 1)

            -- Only move if there's a meaningful delta
            if smoothed.Magnitude > 0.5 then
                mousemoverel(smoothed.X, smoothed.Y)
            end

            -- Crosshair at target bone screen pos
            updateCrosshair(targetScreen, true)

            State.lockedTarget = bestPlayer
            State.crossVisible = true
        else
            hideCrosshair()
            State.crossVisible = false
            State.lockedTarget = nil
        end
    end)
end

