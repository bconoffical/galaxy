local function clearESP()
    for _,h in ipairs(State.espHL) do pcall(function() h:Destroy() end) end
    State.espHL={}
end
local function applyESP()
    clearESP(); if not CFG.ESPOn then return end
    for _,p in ipairs(Players:GetPlayers()) do
        if not isEnemy(p) then continue end
        local ch=p.Character; if not ch then continue end
        local h=Instance.new("Highlight")
        h.DepthMode=CFG.ESPWalls and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.Occluded
        h.FillColor=Color3.fromRGB(180,60,255)
        h.FillTransparency=CFG.ESPOutlineOnly and 1 or 0.5
        h.OutlineColor=Color3.fromRGB(255,160,255); h.OutlineTransparency=0
        h.Adornee=ch; h.Parent=ch
        State.espHL[#State.espHL+1]=h
    end
end
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function() task.wait(0.8); applyESP() end)
end)
for _,p in ipairs(Players:GetPlayers()) do
    if p~=LP then p.CharacterAdded:Connect(function() task.wait(0.8); applyESP() end) end
end

