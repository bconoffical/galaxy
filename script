-- ══════════════════════════════════════
-- AIMBOT — proximity auto-lock
-- Finds nearest enemy head on screen.
-- Locks when cursor is within AimFOV px.
-- Releases when cursor moves > AimBreakDist px from locked head.
-- Cursor is warped to head each frame while locked.
-- ══════════════════════════════════════
local function stopAimbot()
    if State.aimConn then State.aimConn:Disconnect(); State.aimConn = nil end
    hideCross()
    State.lockedTarget = nil
    State.lockedHead   = nil
    pcall(function() Cam.CameraType = Enum.CameraType.Custom end)
end

local function startAimbot()
    stopAimbot()
    State.aimConn = RunService.RenderStepped:Connect(function()
        if not CFG.AimOn then return end

        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not root then hideCross(); return end

        local mouse = UserInput:GetMouseLocation()
        local mVec  = Vector2.new(mouse.X, mouse.Y)

        -- ── If currently locked, check break distance ──────────
        if State.lockedTarget and State.lockedHead then
            local ch = State.lockedTarget.Character
            -- Target died / left
            if not ch or not ch:FindFirstChild("Head")
            or not State.lockedTarget.Parent then
                State.lockedTarget = nil
                State.lockedHead   = nil
            else
                local sp, onS = Cam:WorldToViewportPoint(State.lockedHead.Position)
                local headScreen = Vector2.new(sp.X, sp.Y)
                local breakDist  = (mVec - headScreen).Magnitude

                if not onS or breakDist > CFG.AimBreakDist then
                    -- Cursor moved away — release lock
                    State.lockedTarget = nil
                    State.lockedHead   = nil
                    State.lockCooldown = true
                    task.delay(0.25, function() State.lockCooldown = false end)
                end
            end
        end

        -- ── If not locked, find nearest head within FOV ────────
        if not State.lockedTarget and not State.lockCooldown then
            local bestHead, bestPlayer, bestDist = nil, nil, math.huge

            for _, p in ipairs(Players:GetPlayers()) do
                if not isEnemy(p) then continue end
                local ch = p.Character; if not ch then continue end
                local head = ch:FindFirstChild("Head")
                local hrp  = ch:FindFirstChild("HumanoidRootPart")
                local target = head or hrp
                if not target then continue end

                local worldDist = (target.Position - root.Position).Magnitude
                if worldDist > CFG.AimMaxDist then continue end

                local sp, onS = Cam:WorldToViewportPoint(target.Position)
                if not onS then continue end

                local screenDist = (Vector2.new(sp.X, sp.Y) - mVec).Magnitude
                if screenDist < CFG.AimFOV and screenDist < bestDist then
                    bestDist   = screenDist
                    bestHead   = target
                    bestPlayer = p
                end
            end

            if bestHead then
                State.lockedTarget = bestPlayer
                State.lockedHead   = bestHead
            end
        end

        -- ── Apply lock ─────────────────────────────────────────
        if State.lockedTarget and State.lockedHead then
            local ch = State.lockedTarget.Character
            if not ch then hideCross(); return end

            -- Smooth camera toward head
            if Cam.CameraType ~= Enum.CameraType.Scriptable then
                Cam.CameraType = Enum.CameraType.Scriptable
            end
            Cam.CFrame = Cam.CFrame:Lerp(
                CFrame.new(Cam.CFrame.Position, State.lockedHead.Position),
                math.clamp(CFG.AimSmooth, 0.01, 1)
            )

            -- Warp cursor onto head screen position
            local sp2 = Cam:WorldToViewportPoint(State.lockedHead.Position)
            local headVP = Vector2.new(sp2.X, sp2.Y)
            pcall(function()
                UserInput:SetMouseLocation(headVP.X, headVP.Y)
            end)

            showCross(headVP, Color3.fromRGB(255, 75, 75))
        else
            hideCross()
            if Cam.CameraType == Enum.CameraType.Scriptable then
                Cam.CameraType = Enum.CameraType.Custom
            end
        end
    end)
end

-- ══════════════════════════════════════
-- FLY
-- ══════════════════════════════════════
local function stopFly()
    RunService:UnbindFromRenderStep("GalaxiusFly")
    if State.flyBV and State.flyBV.Parent then State.flyBV:Destroy() end
    if State.flyBG and State.flyBG.Parent then State.flyBG:Destroy() end
    State.flyBV = nil; State.flyBG = nil
    local ch  = LP.Character
    local hm  = ch and ch:FindFirstChildOfClass("Humanoid")
    if hm then
        hm:ChangeState(Enum.HumanoidStateType.Falling)
        task.delay(0.1, function()
            if hm and hm.Parent then hm:ChangeState(Enum.HumanoidStateType.GettingUp) end
        end)
    end
end

local function startFly()
    local ch   = LP.Character
    local root = ch and ch:FindFirstChild("HumanoidRootPart")
    local hm   = ch and ch:FindFirstChildOfClass("Humanoid")
    if not root or not hm then return end
    stopFly()
    task.wait(0.05)
    ch   = LP.Character
    root = ch and ch:FindFirstChild("HumanoidRootPart")
    hm   = ch and ch:FindFirstChildOfClass("Humanoid")
    if not root or not hm then return end

    hm:ChangeState(Enum.HumanoidStateType.Physics)
    State.flyBV = Instance.new("BodyVelocity", root)
    State.flyBV.MaxForce = Vector3.new(1e5,1e5,1e5)
    State.flyBV.Velocity = Vector3.zero
    State.flyBV.P        = 1e4
    State.flyBG = Instance.new("BodyGyro", root)
    State.flyBG.MaxTorque = Vector3.new(1e5,1e5,1e5)
    State.flyBG.P = 1e4; State.flyBG.D = 100
    State.flyBG.CFrame = root.CFrame

    RunService:BindToRenderStep("GalaxiusFly", Enum.RenderPriority.Input.Value, function()
        local r   = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        local hum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
        if not r or not CFG.FlyOn then stopFly(); return end
        if hum and hum:GetState() ~= Enum.HumanoidStateType.Physics then
            hum:ChangeState(Enum.HumanoidStateType.Physics)
        end
        local cf  = Cam.CFrame
        local mv  = Vector3.zero
        local fwd = Vector3.new(cf.LookVector.X, 0, cf.LookVector.Z)
        local rgt = Vector3.new(cf.RightVector.X, 0, cf.RightVector.Z)
        if fwd.Magnitude > 0.01 then fwd = fwd.Unit end
        if rgt.Magnitude > 0.01 then rgt = rgt.Unit end
        if UserInput:IsKeyDown(Enum.KeyCode.W) then mv = mv + fwd end
        if UserInput:IsKeyDown(Enum.KeyCode.S) then mv = mv - fwd end
        if UserInput:IsKeyDown(Enum.KeyCode.A) then mv = mv - rgt end
        if UserInput:IsKeyDown(Enum.KeyCode.D) then mv = mv + rgt end
        if UserInput:IsKeyDown(Enum.KeyCode.Space)        then mv = mv + Vector3.yAxis end
        if UserInput:IsKeyDown(Enum.KeyCode.LeftControl)
        or UserInput:IsKeyDown(Enum.KeyCode.LeftShift)    then mv = mv - Vector3.yAxis end
        State.flyBV.Velocity = mv.Magnitude > 0 and mv.Unit * CFG.FlySpeed or Vector3.zero
        if fwd.Magnitude > 0.01 then
            State.flyBG.CFrame = CFrame.new(r.Position, r.Position + fwd)
        end
    end)
end

-- ══════════════════════════════════════
-- NOCLIP
-- ══════════════════════════════════════
local function stopNoclip()
    if State.noclipConn then State.noclipConn:Disconnect(); State.noclipConn = nil end
    local ch = LP.Character; if not ch then return end
    for _, p in ipairs(ch:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = true end
    end
end
local function startNoclip()
    stopNoclip()
    State.noclipConn = RunService.Stepped:Connect(function()
        if not CFG.NoclipOn then stopNoclip(); return end
        local ch = LP.Character; if not ch then return end
        for _, p in ipairs(ch:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)
end

-- ══════════════════════════════════════
-- SAVE / LOAD
-- ══════════════════════════════════════
local CFG_FILE = "Galaxius_v110.txt"
local function saveCFG()
    pcall(function()
        local t = {}
        for k,v in pairs(CFG)  do t[#t+1] = k.."="..tostring(v) end
        for k,v in pairs(KEYS) do t[#t+1] = "KEY_"..k.."="..tostring(v) end
        writefile(CFG_FILE, table.concat(t,"\n"))
    end)
end
local function loadCFG()
    pcall(function()
        if not isfile(CFG_FILE) then return end
        for line in readfile(CFG_FILE):gmatch("[^\n]+") do
            local k,v = line:match("([^=]+)=(.*)")
            if not k then continue end
            local kk = k:match("^KEY_(.+)$")
            if kk and KEYS[kk] ~= nil then KEYS[kk] = v
            elseif CFG[k] ~= nil then
                if     type(CFG[k])=="boolean" then CFG[k]=(v=="true")
                elseif type(CFG[k])=="number"  then CFG[k]=tonumber(v) or CFG[k] end
            end
        end
    end)
end
loadCFG()

