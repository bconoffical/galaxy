task.spawn(function()
    local hue=0
    while hud and hud.Parent do
        task.wait(0.07); hue=(hue+0.002)%1
        local rc=hsv(hue,0.8,1)
        hudStroke.Color=rc; hudBar.BackgroundColor3=rc; hudDot.BackgroundColor3=rc
        border.Color=rc; accentLine.BackgroundColor3=rc; sbAccent.BackgroundColor3=rc
        lmStroke.Color=rc

        -- Status
        if State.lockedTarget and CFG.AimOn then
            statusDot.BackgroundColor3=Color3.fromRGB(255,70,70)
            statusLbl.Text="🎯 "..State.lockedTarget.Name
            statusLbl.TextColor3=Color3.fromRGB(255,80,80)
        elseif CFG.AimOn then
            statusDot.BackgroundColor3=Color3.fromRGB(80,220,100)
            statusLbl.Text="◉ SCANNING"
            statusLbl.TextColor3=Color3.fromRGB(90,225,110)
        else
            statusDot.BackgroundColor3=Color3.fromRGB(90,85,120)
            statusLbl.Text="OFFLINE"
            statusLbl.TextColor3=Color3.fromRGB(100,85,140)
        end

        -- HUD status
        if State.lockedTarget and CFG.AimOn then
            hudStatus2.Text="🎯 LOCKED → "..State.lockedTarget.Name
            hudStatus2.TextColor3=Color3.fromRGB(255,80,80)
        else
            local parts={}
            if CFG.AimOn      then parts[#parts+1]="◉ AIM"  end
            if CFG.ESPOn      then parts[#parts+1]="◈ ESP"  end
            if CFG.FlyOn      then parts[#parts+1]="✈ FLY"  end
            if CFG.NoclipOn   then parts[#parts+1]="◌ CLIP" end
            if CFG.WallHackOn then parts[#parts+1]="◆ WALL" end
            if #parts>0 then
                hudStatus2.Text=table.concat(parts,"  ·  ")
                hudStatus2.TextColor3=Color3.fromRGB(200,150,255)
            else
                hudStatus2.Text="TAB = Menu  ·  ` = Aimbot"
                hudStatus2.TextColor3=Color3.fromRGB(140,95,200)
            end
        end
    end
end)

-- Nebula drift
task.spawn(function()
    local t=0
    while main and main.Parent do
        task.wait(0.05); t=t+0.014
        for i,nf in ipairs(State.nebulaObjs) do
            nf.Position=UDim2.new(
                nf.Position.X.Scale,nf.Position.X.Offset,
                nf.Position.Y.Scale,nf.Position.Y.Offset+math.sin(t*0.25+i*1.2)*0.04)
        end
    end
end)

