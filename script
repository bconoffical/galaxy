local function stopAimbot()
    if State.aimConn then State.aimConn:Disconnect(); State.aimConn=nil end
end

local function startAimbot()
    stopAimbot()
    State.aimConn = RunService.RenderStepped:Connect(function()
        if not CFG.AimOn then return end
        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not root then return end

        local center = Cam.ViewportSize * 0.5
        local bestHead, bestDist = nil, math.huge

        for _,p in ipairs(Players:GetPlayers()) do
            if not isEnemy(p) then continue end
            local ch=p.Character; if not ch then continue end
            local head=ch:FindFirstChild("Head"); if not head then continue end

            -- Through-wall aimbot: skip visibility check entirely
            -- (for wall-shoot mode) or do soft check
            local sp, onS = Cam:WorldToViewportPoint(head.Position)
            -- In wallshoot mode we still aim even if not onScreen
            local screenPos = Vector2.new(sp.X, sp.Y)
            local fovDist = (screenPos - center).Magnitude
            local worldDist = (head.Position - root.Position).Magnitude

            if fovDist <= CFG.AimFOV and worldDist <= CFG.AimMaxDist then
                if fovDist < bestDist then
                    bestDist = fovDist
                    bestHead = head
                end
            end
        end

        if bestHead then
            if Cam.CameraType ~= Enum.CameraType.Scriptable then
                Cam.CameraType = Enum.CameraType.Scriptable
            end
            local target = CFrame.new(Cam.CFrame.Position, bestHead.Position)
            Cam.CFrame = Cam.CFrame:Lerp(target, math.clamp(CFG.AimSmooth, 0.01, 1))
        else
            if Cam.CameraType == Enum.CameraType.Scriptable and not CFG.FreecamOn then
                Cam.CameraType = Enum.CameraType.Custom
            end
        end
    end)
end

