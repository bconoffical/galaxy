-- FLY
-- ══════════════════════════════════════
local function stopFly()
    RunService:UnbindFromRenderStep("GalaxusFly")
    if State.flyBV and State.flyBV.Parent then State.flyBV:Destroy() end
    if State.flyBG and State.flyBG.Parent then State.flyBG:Destroy() end
    State.flyBV=nil; State.flyBG=nil
    local hm=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
    if hm then hm:ChangeState(Enum.HumanoidStateType.GettingUp) end
end

local function startFly()
    local ch=LP.Character
    local root=ch and ch:FindFirstChild("HumanoidRootPart")
    local hm=ch and ch:FindFirstChildOfClass("Humanoid")
    if not root or not hm then return end
    stopFly()
    hm:ChangeState(Enum.HumanoidStateType.Physics)
    State.flyBV=Instance.new("BodyVelocity",root)
    State.flyBV.MaxForce=Vector3.new(1e6,1e6,1e6); State.flyBV.Velocity=Vector3.zero
    State.flyBG=Instance.new("BodyGyro",root)
    State.flyBG.MaxTorque=Vector3.new(1e6,1e6,1e6); State.flyBG.P=20000; State.flyBG.CFrame=root.CFrame
    RunService:BindToRenderStep("GalaxusFly",199,function()
        local r=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not r or not CFG.FlyOn then stopFly(); return end
        local hum=LP.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.Physics) end
        local cf=Cam.CFrame; local mv=Vector3.zero
        if UserInput:IsKeyDown(Enum.KeyCode.W) then mv+=cf.LookVector end
        if UserInput:IsKeyDown(Enum.KeyCode.S) then mv-=cf.LookVector end
        if UserInput:IsKeyDown(Enum.KeyCode.A) then mv-=cf.RightVector end
        if UserInput:IsKeyDown(Enum.KeyCode.D) then mv+=cf.RightVector end
        if UserInput:IsKeyDown(Enum.KeyCode.Space) then mv+=Vector3.yAxis end
        if UserInput:IsKeyDown(Enum.KeyCode.LeftControl) or UserInput:IsKeyDown(Enum.KeyCode.LeftShift) then
            mv-=Vector3.yAxis end
        State.flyBV.Velocity=mv.Magnitude>0 and mv.Unit*CFG.FlySpeed or State.flyBV.Velocity*0.75
        State.flyBG.CFrame=CFrame.new(r.Position,r.Position+cf.LookVector*Vector3.new(1,0,1))
    end)
end

