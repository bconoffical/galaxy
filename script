LP.CharacterAdded:Connect(function()
    task.wait(1.2)
    applyESP()
    if CFG.FlyOn      then task.wait(0.3); startFly()   end
    if CFG.NoclipOn   then startNoclip()                 end
    if CFG.WallHackOn then task.wait(0.3); applyWallHL() end
    if CFG.AimOn      then startAimbot()                 end
end)

