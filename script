local function isEnemy(p)
    if p==LP then return false end
    if p.Team and LP.Team and p.Team==LP.Team then return false end
    return true
end

local function tw(obj,props,t,style)
    TweenService:Create(obj,TweenInfo.new(t or 0.2,
        style or Enum.EasingStyle.Quart,Enum.EasingDirection.Out),props):Play()
end

local function hsv(h,s,v)
    h=h%1; local i=math.floor(h*6); local f=h*6-i
    local p=v*(1-s); local q=v*(1-f*s); local r=v*(1-(1-f)*s)
    local t2={{v,r,p},{q,v,p},{p,v,r},{p,q,v},{r,p,v},{v,p,q}}
    local c=t2[(i%6)+1]; return Color3.new(c[1],c[2],c[3])
end

-- ══════════════════════════════════════
-- DRAWING (single ring + crosshair)
-- ══════════════════════════════════════
local CLEN,CGAP = 11,4

local function initDrawing()
    pcall(function()
        -- ONE ring that follows cursor (FOV indicator)
        State.fovRing = Drawing.new("Circle")
        State.fovRing.Visible      = false
        State.fovRing.Filled       = false
        State.fovRing.Color        = Color3.fromRGB(160,60,255)
        State.fovRing.Transparency = 0.45
        State.fovRing.Thickness    = 1.4
        State.fovRing.Radius       = CFG.AimFOV

        -- Crosshair lines (4 arms + dot) — appear on locked head
        local function ln()
            local l = Drawing.new("Line")
            l.Visible=false; l.Thickness=1.6
            l.Color=Color3.fromRGB(255,65,65); l.Transparency=0
            return l
        end
        State.crossH   = ln()
        State.crossV   = ln()
        State.crossTop = ln()
        State.crossBot = ln()

        State.crossDot = Drawing.new("Circle")
        State.crossDot.Visible=false; State.crossDot.Filled=true
        State.crossDot.Radius=2.8; State.crossDot.Thickness=1
        State.crossDot.Color=Color3.fromRGB(255,255,255); State.crossDot.Transparency=0
    end)
end

local function showCross(sp)
    pcall(function()
        local cx,cy = sp.X, sp.Y
        State.crossH.From=Vector2.new(cx-CLEN-CGAP,cy); State.crossH.To=Vector2.new(cx-CGAP,cy);            State.crossH.Visible=true
        State.crossV.From=Vector2.new(cx+CGAP,cy);       State.crossV.To=Vector2.new(cx+CLEN+CGAP,cy);      State.crossV.Visible=true
        State.crossTop.From=Vector2.new(cx,cy-CLEN-CGAP);State.crossTop.To=Vector2.new(cx,cy-CGAP);         State.crossTop.Visible=true
        State.crossBot.From=Vector2.new(cx,cy+CGAP);     State.crossBot.To=Vector2.new(cx,cy+CLEN+CGAP);    State.crossBot.Visible=true
        State.crossDot.Position=Vector2.new(cx,cy); State.crossDot.Color=Color3.fromRGB(255,60,60); State.crossDot.Visible=true
    end)
end

local function hideCross()
    pcall(function()
        for _,k in ipairs({"crossH","crossV","crossTop","crossBot","crossDot"}) do
            if State[k] then State[k].Visible=false end
        end
    end)
end

local function hideAll()
    hideCross()
    pcall(function() if State.fovRing then State.fovRing.Visible=false end end)
end

initDrawing()

