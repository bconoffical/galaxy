-- ══════════════════════════════════════
-- AIMBOT
-- One ring follows cursor.
-- When locked: ring hides, crosshair shows on head.
-- When unlocked: ring shows, crosshair hides.
-- ══════════════════════════════════════
local function stopAimbot()
    if State.aimConn then State.aimConn:Disconnect(); State.aimConn=nil end
    hideAll()
    State.lockedTarget=nil
    pcall(function() Cam.CameraType=Enum.CameraType.Custom end)
end

local function startAimbot()
    stopAimbot()
    State.aimConn=RunService.RenderStepped:Connect(function()
        if not CFG.AimOn then return end

        local root=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not root then hideAll(); return end

        local mouse=UserInput:GetMouseLocation()
        local mVec=Vector2.new(mouse.X, mouse.Y)

        local bestHead, bestPlayer, bestDist = nil, nil, math.huge

        for _,p in ipairs(Players:GetPlayers()) do
            if not isEnemy(p) then continue end
            local ch=p.Character; if not ch then continue end
            local head=ch:FindFirstChild("Head"); if not head then continue end
            if (head.Position-root.Position).Magnitude > CFG.AimMaxDist then continue end
            local sp, onS = Cam:WorldToViewportPoint(head.Position)
            if not onS then continue end
            local fd = (Vector2.new(sp.X,sp.Y) - mVec).Magnitude
            if fd <= CFG.AimFOV and fd < bestDist then
                bestDist=fd; bestHead=head; bestPlayer=p
            end
        end

        if bestHead then
            -- LOCKED: hide ring, show crosshair on head
            pcall(function() if State.fovRing then State.fovRing.Visible=false end end)

            if Cam.CameraType ~= Enum.CameraType.Scriptable then
                Cam.CameraType = Enum.CameraType.Scriptable
            end
            Cam.CFrame = Cam.CFrame:Lerp(
                CFrame.new(Cam.CFrame.Position, bestHead.Position),
                math.clamp(CFG.AimSmooth, 0.01, 1))

            local sp2 = Cam:WorldToViewportPoint(bestHead.Position)
            showCross(Vector2.new(sp2.X, sp2.Y))
            State.lockedTarget = bestPlayer
        else
            -- UNLOCKED: show ring at cursor, hide crosshair
            hideCross()
            State.lockedTarget = nil
            pcall(function()
                if State.fovRing then
                    State.fovRing.Position = mVec
                    State.fovRing.Radius   = CFG.AimFOV
                    State.fovRing.Visible  = true
                end
            end)
            if Cam.CameraType == Enum.CameraType.Scriptable then
                Cam.CameraType = Enum.CameraType.Custom
            end
        end
    end)
end

-- ══════════════════════════════════════
-- FLY  (fixed — no stuck-in-place bug)
-- ══════════════════════════════════════
local function stopFly()
    RunService:UnbindFromRenderStep("GalaxiusFly")
    if State.flyBV and State.flyBV.Parent then State.flyBV:Destroy() end
    if State.flyBG and State.flyBG.Parent then State.flyBG:Destroy() end
    State.flyBV=nil; State.flyBG=nil
    -- Return humanoid to normal state
    local ch=LP.Character
    local hm=ch and ch:FindFirstChildOfClass("Humanoid")
    if hm then
        hm:ChangeState(Enum.HumanoidStateType.Falling)
        task.delay(0.1, function()
            if hm and hm.Parent then
                hm:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end)
    end
end

local function startFly()
    local ch   = LP.Character
    local root = ch and ch:FindFirstChild("HumanoidRootPart")
    local hm   = ch and ch:FindFirstChildOfClass("Humanoid")
    if not root or not hm then return end

    stopFly()

    -- Small delay so stopFly cleanup finishes
    task.wait(0.05)

    ch   = LP.Character
    root = ch and ch:FindFirstChild("HumanoidRootPart")
    hm   = ch and ch:FindFirstChildOfClass("Humanoid")
    if not root or not hm then return end

    hm:ChangeState(Enum.HumanoidStateType.Physics)

    State.flyBV = Instance.new("BodyVelocity", root)
    State.flyBV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    State.flyBV.Velocity = Vector3.zero
    State.flyBV.P        = 1e4

    State.flyBG = Instance.new("BodyGyro", root)
    State.flyBG.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    State.flyBG.P         = 1e4
    State.flyBG.D         = 100
    State.flyBG.CFrame    = root.CFrame

    RunService:BindToRenderStep("GalaxiusFly", Enum.RenderPriority.Input.Value, function()
        local r  = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        local hum= LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
        if not r or not CFG.FlyOn then stopFly(); return end

        -- Keep in physics state every frame
        if hum and hum:GetState() ~= Enum.HumanoidStateType.Physics then
            hum:ChangeState(Enum.HumanoidStateType.Physics)
        end

        local cf = Cam.CFrame
        local mv = Vector3.zero

        if UserInput:IsKeyDown(Enum.KeyCode.W) then mv = mv + cf.LookVector end
        if UserInput:IsKeyDown(Enum.KeyCode.S) then mv = mv - cf.LookVector end
        if UserInput:IsKeyDown(Enum.KeyCode.A) then mv = mv - cf.RightVector end
        if UserInput:IsKeyDown(Enum.KeyCode.D) then mv = mv + cf.RightVector end
        if UserInput:IsKeyDown(Enum.KeyCode.Space) then mv = mv + Vector3.yAxis end
        if UserInput:IsKeyDown(Enum.KeyCode.LeftControl)
        or UserInput:IsKeyDown(Enum.KeyCode.LeftShift) then
            mv = mv - Vector3.yAxis
        end

        -- Zero out y from camera look so W/S don't fight vertical
        local flatLook = Vector3.new(cf.LookVector.X, 0, cf.LookVector.Z)
        if UserInput:IsKeyDown(Enum.KeyCode.W) then
            mv = mv - cf.LookVector + flatLook end
        if UserInput:IsKeyDown(Enum.KeyCode.S) then
            mv = mv + cf.LookVector - flatLook end

        if mv.Magnitude > 0 then
            State.flyBV.Velocity = mv.Unit * CFG.FlySpeed
        else
            -- Instantly stop instead of drifting
            State.flyBV.Velocity = Vector3.zero
        end

        -- Keep character upright facing camera direction
        local lookFlat = cf.LookVector * Vector3.new(1,0,1)
        if lookFlat.Magnitude > 0.01 then
            State.flyBG.CFrame = CFrame.new(r.Position, r.Position + lookFlat)
        end
    end)
end

-- ══════════════════════════════════════
-- NOCLIP
-- ══════════════════════════════════════
local function stopNoclip()
    if State.noclipConn then State.noclipConn:Disconnect(); State.noclipConn=nil end
    local ch=LP.Character; if not ch then return end
    for _,p in ipairs(ch:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide=true end
    end
end
local function startNoclip()
    stopNoclip()
    State.noclipConn=RunService.Stepped:Connect(function()
        if not CFG.NoclipOn then stopNoclip(); return end
        local ch=LP.Character; if not ch then return end
        for _,p in ipairs(ch:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=false end
        end
    end)
end

