-- CONFIG SAVE / LOAD
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
local CFG_FILE="Galaxus_v53.txt"
local function saveCFG()
    pcall(function()
        local t={}
        for k,v in pairs(CFG) do t[#t+1]=k.."="..tostring(v) end
        for k,v in pairs(BINDS) do t[#t+1]="BIND_"..k.."="..tostring(v) end
        writefile(CFG_FILE,table.concat(t,"\n"))
    end)
end
local function loadCFG()
    pcall(function()
        if not isfile(CFG_FILE) then return end
        for line in readfile(CFG_FILE):gmatch("[^\n]+") do
            local k,v=line:match("([^=]+)=(.*)")
            if k and v then
                if k:sub(1,5)=="BIND_" then
                    local bk=k:sub(6)
                    if BINDS[bk]~=nil then BINDS[bk]=v end
                elseif CFG[k]~=nil then
                    if type(CFG[k])=="boolean" then CFG[k]=(v=="true")
                    elseif type(CFG[k])=="number" then CFG[k]=tonumber(v) or CFG[k]
                    else CFG[k]=v end
                end
            end
        end
    end)
end
loadCFG()

