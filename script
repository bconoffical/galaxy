-- ANIMATION LOOPS
-- ══════════════════════════════════════
task.spawn(function()
    local hue=0
    while hudStrip and hudStrip.Parent do
        task.wait(0.07); hue=(hue+0.0022)%1
        local rc=hsv(hue,0.85,1)
        hsStroke.Color=rc; hudBar.BackgroundColor3=rc
        border.Color=rc; accentLine.BackgroundColor3=rc; sideAccent.BackgroundColor3=rc

        if State.lockedTarget and CFG.AimOn then
            statusLbl.Text="🎯 "..State.lockedTarget.Name
            statusLbl.TextColor3=Color3.fromRGB(255,80,80)
        elseif CFG.AimOn then
            statusLbl.Text="◉ SCANNING"
            statusLbl.TextColor3=Color3.fromRGB(80,220,120)
        else
            statusLbl.Text="OFFLINE"
            statusLbl.TextColor3=Color3.fromRGB(110,80,160)
        end

        if State.lockedTarget and CFG.AimOn then
            hudStatus.Text="🎯 LOCKED: "..State.lockedTarget.Name
            hudStatus.TextColor3=Color3.fromRGB(255,80,80)
        else
            local parts={}
            if CFG.AimOn      then parts[#parts+1]="◉ AIM"  end
            if CFG.ESPOn      then parts[#parts+1]="◈ ESP"  end
            if CFG.FlyOn      then parts[#parts+1]="✈ FLY"  end
            if CFG.NoclipOn   then parts[#parts+1]="◌ CLIP" end
            if CFG.WallHackOn then parts[#parts+1]="◆ WALL" end
            if #parts>0 then
                hudStatus.Text=table.concat(parts,"  ·  ")
                hudStatus.TextColor3=Color3.fromRGB(200,150,255)
            else
                hudStatus.Text="TAB = Menu  ·  ` = Aimbot"
                hudStatus.TextColor3=Color3.fromRGB(140,90,200)
            end
        end
    end
end)

-- Nebula drift
task.spawn(function()
    local t=0
    while main and main.Parent do
        task.wait(0.05); t=t+0.016
        for i,neb in ipairs(State.nebulaObjs) do
            neb.Position=UDim2.new(
                neb.Position.X.Scale,neb.Position.X.Offset,
                neb.Position.Y.Scale,neb.Position.Y.Offset+math.sin(t*0.28+i*1.1)*0.05)
        end
    end
end)

-- ══════════════════════════════════════
-- GLOBAL KEYBINDS
-- ══════════════════════════════════════
UserInput.InputBegan:Connect(function(inp,gp)
    if gp then return end
    local k=inp.KeyCode
    if k==gkey("Menu") then
        State.menuOpen=not State.menuOpen
        if State.menuOpen then
            main.Visible=true; main.BackgroundTransparency=0.9
            tw(main,{BackgroundTransparency=0},0.22)
        else
            tw(main,{BackgroundTransparency=1},0.18)
            task.delay(0.2,function() if not State.menuOpen then main.Visible=false end end)
        end
    end
    if k==gkey("Aimbot") then
        CFG.AimOn=not CFG.AimOn
        if CFG.AimOn then startAimbot() else stopAimbot() end
    end
    if k==gkey("Fly") then
        CFG.FlyOn=not CFG.FlyOn
        if CFG.FlyOn then startFly() else stopFly() end; saveCFG()
    end
    if k==gkey("Noclip") then
        CFG.NoclipOn=not CFG.NoclipOn
        if CFG.NoclipOn then startNoclip() else stopNoclip() end; saveCFG()
    end
    if k==gkey("WallHack") then
        CFG.WallHackOn=not CFG.WallHackOn
        applyWallHL(); saveCFG()
    end
end)

