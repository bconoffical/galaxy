local function switchTab(idx)
    activeTab=idx
    for i,pg in ipairs(PAGES) do pg.Visible=(i==idx) end
    for i,tb in ipairs(TABS) do
        local on=(i==idx)
        tw(tb.bg,{
            BackgroundColor3=on and Color3.fromRGB(100,28,200) or Color3.fromRGB(10,4,28),
            BackgroundTransparency=on and 0.05 or 0.6,
        })
        tb.activeLine.Visible=on
        tw(tb.icon,{TextColor3=on and Color3.fromRGB(255,215,255) or Color3.fromRGB(130,85,190)})
        tw(tb.lbl, {TextColor3=on and Color3.fromRGB(255,215,255) or Color3.fromRGB(110,75,170),
                    TextTransparency=on and 0 or 0.3})
    end
end

