-- ESP BOXES вЂ” 2D bounding box per enemy
-- Green = visible, Red = behind wall
-- Optimized: head+feet projection only, raycasts throttled to ~6fps
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

local function newBoxLines()
    local lines = {}
    for i = 1, 4 do
        local l = Drawing.new("Line")
        l.Visible     = false
        l.Thickness   = 1.8
        l.Color       = Color3.fromRGB(0, 255, 80)
        l.Transparency = 0
        lines[i] = l
    end
    return lines
end

local function destroyBoxLines(lines)
    for _, l in ipairs(lines) do pcall(function() l:Destroy() end) end
end

local function setBoxColor(lines, col)
    for _, l in ipairs(lines) do l.Color = col end
end

local function drawBox(lines, x, y, w, h)
    lines[1].From = Vector2.new(x,     y);   lines[1].To = Vector2.new(x + w, y)
    lines[2].From = Vector2.new(x,     y+h); lines[2].To = Vector2.new(x + w, y+h)
    lines[3].From = Vector2.new(x,     y);   lines[3].To = Vector2.new(x,     y+h)
    lines[4].From = Vector2.new(x + w, y);   lines[4].To = Vector2.new(x + w, y+h)
    for _, l in ipairs(lines) do l.Visible = true end
end

local function hideBox(lines)
    for _, l in ipairs(lines) do l.Visible = false end
end

-- Fast box: project Head top and HumanoidRootPart bottom to get screen rect.
-- No corner sampling вЂ” two WorldToViewportPoint calls per player.
local function getCharBoxFast(ch)
    local head = ch:FindFirstChild("Head")
    local root = ch:FindFirstChild("HumanoidRootPart")
    if not head or not root then return nil end

    local headSP = Cam:WorldToViewportPoint(head.Position + Vector3.new(0, head.Size.Y * 0.5, 0))
    local rootSP = Cam:WorldToViewportPoint(root.Position - Vector3.new(0, root.Size.Y * 0.5, 0))

    -- Both must be in front of camera
    if headSP.Z <= 0 or rootSP.Z <= 0 then return nil end

    local vp   = Cam.ViewportSize
    local topY = math.clamp(math.min(headSP.Y, rootSP.Y), 0, vp.Y)
    local botY = math.clamp(math.max(headSP.Y, rootSP.Y), 0, vp.Y)
    local h    = botY - topY
    if h < 6 then return nil end

    -- Width proportional to height (typical character aspect)
    local w    = h * 0.55
    local midX = math.clamp((headSP.X + rootSP.X) * 0.5, 0, vp.X)
    local x    = math.clamp(midX - w * 0.5, 0, vp.X)
    w = math.min(w, vp.X - x)

    return x, topY, w, h
end

-- Per-player visibility cache: updated every ~10 frames to avoid raycast spam
local visCache  = {}   -- [UserId] = true/false
local visTick   = {}   -- [UserId] = last update frame index
local frameIdx  = 0
local VIS_INTERVAL = 10  -- update visibility every N frames

local function clearBoxes()
    for _, lines in pairs(State.boxDrawings) do destroyBoxLines(lines) end
    State.boxDrawings = {}
    visCache = {}; visTick = {}
    if State.boxConn then State.boxConn:Disconnect(); State.boxConn = nil end
end

local function startBoxes()
    clearBoxes()
    if not CFG.ESPBoxes then return end

    State.boxConn = RunService.RenderStepped:Connect(function()
        if not CFG.ESPBoxes then clearBoxes(); return end

        frameIdx = frameIdx + 1
        local active = {}

        for _, p in ipairs(Players:GetPlayers()) do
            if not isEnemy(p) then continue end
            local ch  = p.Character; if not ch then continue end
            local pid = p.UserId
            active[pid] = true

            -- Create lines on demand
            if not State.boxDrawings[pid] then
                State.boxDrawings[pid] = newBoxLines()
            end
            local lines = State.boxDrawings[pid]

            local root = ch:FindFirstChild("HumanoidRootPart")
            if not root then hideBox(lines); continue end

            -- Fast box from head+root only
            local x, y, w, h = getCharBoxFast(ch)
            if not x then hideBox(lines); continue end

            -- Throttled visibility raycast
            if (visTick[pid] or 0) + VIS_INTERVAL <= frameIdx then
                visCache[pid] = isVisible(root.Position)
                visTick[pid]  = frameIdx
            end

            local col = (visCache[pid] ~= false)
                and Color3.fromRGB(0, 255, 80)
                or  Color3.fromRGB(255, 40, 40)
            setBoxColor(lines, col)
            drawBox(lines, x, y, w, h)
        end

        -- Remove lines for players who left
        for pid, lines in pairs(State.boxDrawings) do
            if not active[pid] then
                destroyBoxLines(lines)
                State.boxDrawings[pid] = nil
                visCache[pid] = nil; visTick[pid] = nil
            end
        end
    end)
end

-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
-- AIMBOT вЂ” Cursor-only (mousemoverel)
--
-- THE FIX for cursor repel:
--   GetMouseLocation() returns OS cursor pos which does NOT update
--   within the same frame after mousemoverel(). Calling it every frame
--   while tracking means our "current" position is always one frame
--   behind, so delta overshoots and the cursor bounces away.
--
--   Solution: seed vCursor ONCE from GetMouseLocation() when we first
--   acquire a target. While we have a target, ONLY update vCursor by
--   adding our own move vectors вЂ” never call GetMouseLocation() again
--   until the target is lost. This way delta is always 100% accurate.
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

local vCursor        = Vector2.new(0, 0)
local vCursorSeeded  = false   -- have we seeded from real mouse yet?

local function aimActive()
    if CFG.AimHold then return State.aimHolding end
    return CFG.AimOn
end

local function stopAimbot()
    if State.aimConn then State.aimConn:Disconnect(); State.aimConn = nil end
    hideCrosshair()
    pcall(function() if State.fovRing then State.fovRing.Visible = false end end)
    State.lockedTarget = nil
    vCursorSeeded = false  -- force re-seed next activation
end

local function startAimbot()
    stopAimbot()
    vCursorSeeded = false

    State.aimConn = RunService.RenderStepped:Connect(function()
        local isActive = aimActive()

        -- FOV ring: show whenever aimbot is "armed" (on OR hold-mode enabled)
        -- regardless of whether we currently have a target
        local showFOV = (CFG.AimOn or CFG.AimHold) and CFG.AimShowFOV
        if State.fovRing then
            if showFOV then
                -- Use real mouse for ring when not tracking (no vCursor drift risk here)
                local mp = isActive and vCursor or UserInput:GetMouseLocation()
                State.fovRing.Position = Vector2.new(mp.X, mp.Y)
                State.fovRing.Radius   = CFG.AimFOV
                State.fovRing.Visible  = true
            else
                State.fovRing.Visible = false
            end
        end

        if not isActive then
            hideCrosshair()
            State.lockedTarget = nil
            vCursorSeeded = false  -- reset so next activation re-seeds cleanly
            return
        end

        -- Seed vCursor from real mouse exactly once when we become active
        if not vCursorSeeded then
            vCursor       = UserInput:GetMouseLocation()
            vCursorSeeded = true
        end

        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not root then hideCrosshair(); State.lockedTarget = nil; return end

        local bestPart   = nil
        local bestPlayer = nil
        local bestDist   = math.huge

        for _, p in ipairs(Players:GetPlayers()) do
            if not isEnemy(p) then continue end
            local ch = p.Character; if not ch then continue end

            local bone = ch:FindFirstChild(CFG.AimBone)
            if not bone then bone = ch:FindFirstChild("HumanoidRootPart") end
            if not bone then continue end

            local worldDist = (bone.Position - root.Position).Magnitude
            if worldDist > CFG.AimMaxDist then continue end

            local sp, onScreen = Cam:WorldToViewportPoint(bone.Position)
            if not onScreen then continue end

            local screenBone = Vector2.new(sp.X, sp.Y)
            local cursorDist = (screenBone - vCursor).Magnitude

            if cursorDist <= CFG.AimFOV and cursorDist < bestDist then
                bestDist   = cursorDist
                bestPart   = bone
                bestPlayer = p
            end
        end

        if bestPart then
            local sp2, onSc2 = Cam:WorldToViewportPoint(bestPart.Position)
            if not onSc2 then
                hideCrosshair()
                State.lockedTarget  = nil
                State.crossVisible  = false
                vCursorSeeded = false  -- lost target, re-seed next frame
                return
            end

            local targetScreen = Vector2.new(sp2.X, sp2.Y)
            local delta        = targetScreen - vCursor  -- always correct direction

            local smooth = math.clamp(CFG.AimSmooth, 0.05, 1.0)
            local move

            if smooth >= 0.95 then
                move = delta  -- instant snap
            else
                -- Simple lerp fraction: smooth=0.05в†’5% per frame, smooth=0.94в†’94%
                -- Feels natural and is predictable
                move = delta * smooth
            end

            if move.Magnitude > 0.05 then
                mousemoverel(move.X, move.Y)
                vCursor = vCursor + move  -- track internally вЂ” never GetMouseLocation here
            end

            -- Update FOV ring to follow vCursor while tracking
            if State.fovRing and CFG.AimShowFOV then
                State.fovRing.Position = vCursor
            end

            updateCrosshair(targetScreen, true)
            State.lockedTarget = bestPlayer
            State.crossVisible = true
        else
            hideCrosshair()
            State.crossVisible  = false
            State.lockedTarget  = nil
            vCursorSeeded = false  -- no target вЂ” re-seed fresh on next lock
        end
    end)
end

